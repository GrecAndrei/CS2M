{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    }
  },
  "Udp": {
    "Port": 4242,
    "BindAddress": "0.0.0.0",
    "ReceiveBufferSize": 4096,
    "MaxDatagramSize": 1500
  },
  "AllowedHosts": "*"
}
